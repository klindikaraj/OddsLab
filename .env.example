# ============================================
# OddsLab — Variabili d'Ambiente (ROOT)
# ============================================
# Copia questo file come .env e inserisci le tue chiavi:
#   cp .env.example .env
# ATTENZIONE: Non committare MAI il file .env su Git!
# ============================================

# Database MySQL
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=oddslab

# The Odds API — quote live (https://the-odds-api.com)
ODDS_API_KEY=inserisci_la_tua_chiave_qui

# OpenAI — report IA (https://platform.openai.com)
OPENAI_API_KEY=sk-inserisci_la_tua_chiave_qui

# football-data.org — risultati calcio (https://www.football-data.org)
FOOTBALLDATA_KEY=inserisci_la_tua_chiave_qui

# balldontlie.io — risultati NBA (https://www.balldontlie.io)
BALLDONTLIE_KEY=inserisci_la_tua_chiave_qui
